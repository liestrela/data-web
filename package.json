{
  "name": "data-web",
  "version": "0.1.0",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot src/main.ts",
    "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun src/main.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prettier": "3.8.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@rschedule/core": "^1.5.0",
    "@rschedule/standard-date-adapter": "^1.5.0",
    "data-web": ".",
    "date-fns": "^4.1.0",
    "react": "^19.2.4",
    "react-calendar": "^6.0.1",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "uuid": "^13.0.0",
    "yet-another-react-lightbox": "^3.31.0"
  }
}
